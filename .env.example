# ─────────────────────────────────────────────────────────────────────────────
# dcr-mcp-agent configuration
# Copy to .env and fill in your values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# --- OAuth 2.0 Authorization Server (required) ---
# Base issuer URL of the OAuth AS. Endpoints are discovered from
# <OAUTH_AS_ISSUER>/.well-known/openid-configuration (RFC 8414).
OAUTH_AS_ISSUER=

# --- Optional endpoint overrides (used if discovery is unavailable) ---
# OAUTH_REGISTRATION_ENDPOINT=
# OAUTH_TOKEN_ENDPOINT=

# --- Dynamic Client Registration (DCR) auth ---
# The registration request is authenticated with HTTP Basic auth using an
# Initial Access Token (IAT) client ID and client secret (both required for DCR).
DCR_CLIENT_ID=
DCR_CLIENT_SECRET=

# Scope sent in the DCR request body (defaults to "scope-dcr" if unset).
# DCR_SCOPE=scope-dcr

# Initial access token for DCR (legacy Bearer flow; not used by the IAT Basic flow).
# OAUTH_INITIAL_ACCESS_TOKEN=

# Space-separated scopes to request at the token endpoint.
# OAUTH_SCOPE=


# --- MCP server (required) ---
MCP_SERVER_URL=

# Tool to invoke and its JSON arguments.
# Defaults to the demo "add" tool with a=9, b=7 if unset.
# MCP_TOOL_NAME=add
# MCP_TOOL_ARGS={"a":9,"b":7}

# --- DCR credential cache ---
# File path to persist client_id/client_secret (written with 0600 perms).
# CLIENT_CREDENTIALS_PATH=.dcr-credentials.json

# --- Logging ---
# LOG_LEVEL=info   # debug | info | warn | error
